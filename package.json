    "dremo:worker:telemetry:golden": "node tools/local-dev-worker/localDevWorkerTelemetryGoldenCheck.ts",
    "dremo:worker:typecheck": "tsc --noEmit --strict --target ES2020 --module ESNext --moduleResolution bundler --allowImportingTsExtensions tools/local-dev-worker/localDevWorkerContract.ts tools/local-dev-worker/localDevWorkerGuards.ts tools/local-dev-worker/localDevWorkerRunner.ts tools/local-dev-worker/localDevWorkerRequestValidation.ts tools/local-dev-worker/localDevWorkerTrace.ts tools/local-dev-worker/localDevWorkerDryRunAdapter.ts tools/local-dev-worker/localDevWorkerFixtures.ts tools/local-dev-worker/localDevWorkerExecutionCapability.ts tools/local-dev-worker/localDevWorkerExecutionManifest.ts tools/local-dev-worker/localDevWorkerExecutionReviewGate.ts tools/local-dev-worker/localDevWorkerExecutionReadiness.ts tools/local-dev-worker/localDevWorkerExecutionReadinessFixtures.ts tools/local-dev-worker/localDevWorkerExecutionConfig.ts tools/local-dev-worker/localDevWorkerDockerProbePolicy.ts tools/local-dev-worker/localDevWorkerDockerDaemonReadinessPolicy.ts tools/local-dev-worker/localDevWorkerDockerReadiness.ts tools/local-dev-worker/localDevWorkerDockerReadinessAdapter.ts tools/local-dev-worker/localDevWorkerDockerReadinessFixtures.ts tools/local-dev-worker/localDevWorkerDockerVersionParser.ts tools/local-dev-worker/localDevWorkerDockerContainerPolicy.ts tools/local-dev-worker/localDevWorkerDockerImagePolicy.ts tools/local-dev-worker/localDevWorkerDockerContainerCommandPolicy.ts tools/local-dev-worker/localDevWorkerDockerContainerPlan.ts tools/local-dev-worker/localDevWorkerDockerContainerReadinessGate.ts tools/local-dev-worker/localDevWorkerDockerContainerPolicyFixtures.ts tools/local-dev-worker/localDevWorkerDockerContainerIdentity.ts tools/local-dev-worker/localDevWorkerDockerCleanupPolicy.ts tools/local-dev-worker/localDevWorkerDockerCleanupPlan.ts tools/local-dev-worker/localDevWorkerDockerCleanupFixtures.ts tools/local-dev-worker/localDevWorkerDockerCleanupAdapter.ts tools/local-dev-worker/localDevWorkerDockerCleanupExecutionFixtures.ts tools/local-dev-worker/localDevWorkerDockerContainerSmokePolicy.ts tools/local-dev-worker/localDevWorkerDockerContainerSmokeAdapter.ts tools/local-dev-worker/localDevWorkerDockerContainerSmokeFixtures.ts tools/local-dev-worker/localDevWorkerDockerSmokeResultNormalizer.ts tools/local-dev-worker/localDevWorkerOutputSanitizer.ts tools/local-dev-worker/localDevWorkerDockerSmokeAudit.ts tools/local-dev-worker/localDevWorkerDockerSmokeAuditFixtures.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecyclePolicy.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycle.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleFixtures.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleReportPolicy.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleReport.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleReportFixtures.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleCliRequests.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleCliFixtures.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleCli.ts tools/local-dev-worker/localDevWorkerGoldenReportCheck.ts tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleGoldenCheck.ts tools/local-dev-worker/localDevWorkerDocsLinkCheck.ts tools/local-dev-worker/localDevWorkerLifecycleTelemetrySchema.ts tools/local-dev-worker/localDevWorkerLifecycleTelemetryPolicy.ts tools/local-dev-worker/localDevWorkerLifecycleTelemetryEvents.ts tools/local-dev-worker/localDevWorkerLifecycleTelemetryFixtures.ts tools/local-dev-worker/localDevWorkerTelemetryGoldenCheck.ts tools/local-dev-worker/localDevWorkerTrustedReview.ts tools/local-dev-worker/localDevWorkerVersionExecutionAdapter.ts tools/local-dev-worker/localDevWorkerVersionExecutionFixtures.ts tools/local-dev-worker/localDevWorkerDryRunSelfCheck.ts tools/local-dev-worker/localDevWorkerDryRunSelfCheckRunner.ts",
