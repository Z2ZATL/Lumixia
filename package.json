    "dremo:worker:lifecycle:report:golden": "node tools/local-dev-worker/localDevWorkerDockerSmokeLifecycleGoldenCheck.ts",
    "dremo:worker:docs": "node tools/local-dev-worker/localDevWorkerDocsLinkCheck.ts",
    "dremo:worker:safety": "node tools/local-dev-worker/localDevWorkerSafetyScan.mjs",
