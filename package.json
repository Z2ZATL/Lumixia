{
  "name": "lumixia",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dremo:worker:safety": "node tools/local-dev-worker/localDevWorkerSafetyScan.mjs",
    "dremo:worker:selfcheck": "node tools/local-dev-worker/localDevWorkerDryRunSelfCheckRunner.ts",
    "dremo:worker:typecheck": "tsc --noEmit --strict --target ES2020 --module ESNext --moduleResolution bundler --allowImportingTsExtensions tools/local-dev-worker/localDevWorkerContract.ts tools/local-dev-worker/localDevWorkerGuards.ts tools/local-dev-worker/localDevWorkerRunner.ts tools/local-dev-worker/localDevWorkerRequestValidation.ts tools/local-dev-worker/localDevWorkerTrace.ts tools/local-dev-worker/localDevWorkerDryRunAdapter.ts tools/local-dev-worker/localDevWorkerFixtures.ts tools/local-dev-worker/localDevWorkerExecutionCapability.ts tools/local-dev-worker/localDevWorkerExecutionManifest.ts tools/local-dev-worker/localDevWorkerExecutionReviewGate.ts tools/local-dev-worker/localDevWorkerExecutionReadiness.ts tools/local-dev-worker/localDevWorkerExecutionReadinessFixtures.ts tools/local-dev-worker/localDevWorkerExecutionConfig.ts tools/local-dev-worker/localDevWorkerDockerProbePolicy.ts tools/local-dev-worker/localDevWorkerDockerDaemonReadinessPolicy.ts tools/local-dev-worker/localDevWorkerDockerReadiness.ts tools/local-dev-worker/localDevWorkerDockerReadinessAdapter.ts tools/local-dev-worker/localDevWorkerDockerReadinessFixtures.ts tools/local-dev-worker/localDevWorkerDockerVersionParser.ts tools/local-dev-worker/localDevWorkerDockerContainerPolicy.ts tools/local-dev-worker/localDevWorkerDockerImagePolicy.ts tools/local-dev-worker/localDevWorkerDockerContainerCommandPolicy.ts tools/local-dev-worker/localDevWorkerDockerContainerPlan.ts tools/local-dev-worker/localDevWorkerDockerContainerReadinessGate.ts tools/local-dev-worker/localDevWorkerDockerContainerPolicyFixtures.ts tools/local-dev-worker/localDevWorkerTrustedReview.ts tools/local-dev-worker/localDevWorkerVersionExecutionAdapter.ts tools/local-dev-worker/localDevWorkerVersionExecutionFixtures.ts tools/local-dev-worker/localDevWorkerDryRunSelfCheck.ts tools/local-dev-worker/localDevWorkerDryRunSelfCheckRunner.ts",
    "dremo:worker:verify": "npm run dremo:worker:typecheck && npm run dremo:worker:selfcheck && npm run dremo:worker:safety"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "framer-motion": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.10"
  }
}
